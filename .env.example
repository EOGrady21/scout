# Database
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Auth.js
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Rate limits (optional)
# Uploads: default 10 requests / 60 seconds
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_WINDOW_MS=60000

# Condition submissions: default 20 requests / 5 minutes
RATE_LIMIT_CONDITIONS_MAX=20
RATE_LIMIT_CONDITIONS_WINDOW_MS=300000

# New locations: default 10 requests / 10 minutes
RATE_LIMIT_LOCATIONS_MAX=10
RATE_LIMIT_LOCATIONS_WINDOW_MS=600000
